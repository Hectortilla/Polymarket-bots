{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Wallets finder (loop)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/wallets_finder.py",
      "args": [
        "--loop"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": true
    },
    {
      "name": "Select wallet for analysis",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/select_wallet_for_analysis.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": true
    }
  ],
  "compounds": [
  ]
}
