{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Wallets finder (loop)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/wallets_finder/__init__.py",
      "args": [
        "--loop"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": true
    },
    {
      "name": "Select wallet for analysis",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.select_wallet_for_analysis",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": true
    },
    {
      "name": "Run polybot CLI",
      "type": "debugpy",
      "request": "launch",
      "module": "polybot.cli",
      "args": [
        "--bot",
        "polybot.my_bot:create"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": true
    },
    {
      "name": "Record BTC 5m buckets",
      "type": "debugpy",
      "request": "launch",
      "module": "polybot.recording",
      "args": [
        "--bot",
        "polybot.examples.btc_5m:create"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": true
    },
    {
      "name": "Inspect recording (pick file)",
      "type": "debugpy",
      "request": "launch",
      "module": "polybot.recording.inspect",
      "args": [
        "${input:pickRecordingFileToInspect}"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": true
    },
    {
      "name": "Trim recording (pick file)",
      "type": "debugpy",
      "request": "launch",
      "module": "polybot.recording.trim",
      "args": [
        "${input:pickRecordingFile}"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": true
    }
  ],
  "compounds": [],
  "inputs": [
    {
      "id": "pickRecordingFileToInspect",
      "type": "command",
      "command": "extension.commandvariable.file.pickFile",
      "args": {
        "description": "Pick a recording SQLite archive to inspect"
      }
    },
    {
      "id": "pickRecordingFile",
      "type": "command",
      "command": "extension.commandvariable.file.pickFile",
      "args": {
        "description": "Pick a recording SQLite archive to trim"
      }
    }
  ]
}
