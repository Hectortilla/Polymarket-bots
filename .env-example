# Copy this file to .env and replace the placeholder values. Do not commit .env.
#
# This topology deliberately covers every valid StreamRule relation:
# - filtered: accept a wallet trade only when both its wallet and market match.
# - independent: accept a wallet trade when either its wallet or market matches.
# - independent rules may be market-only or wallet-only.
#
# All matching rule results are combined. Book events are subscribed for every
# market slug below; wallet trades are accepted when any one rule accepts them.
BOT_MODE=paper
BOT_STREAM_RULES='[{
    "relation": "filtered",
    "market_slugs": ["btc-up", "eth-up"],
    "wallet_addresses": ["0x0000000000000000000000000000000000000001", "0x0000000000000000000000000000000000000002"]
}, {
    "relation": "filtered",
    "market_slugs": ["will-fed-cut-rates"],
    "wallet_addresses": ["0x0000000000000000000000000000000000000003"]
}, {
    "relation": "independent",
    "market_slugs": ["sol-up"],
    "wallet_addresses": ["0x0000000000000000000000000000000000000004"]
}, {
    "relation": "independent",
    "market_slugs": ["btc-down"]
}, {
    "relation": "independent",
    "wallet_addresses": ["0x0000000000000000000000000000000000000005"]
}]'

# Shared order and paper-simulation limits.
BOT_DATA_TRADES_BUDGET_PER_10S=180
BOT_MAX_ORDER_SIZE=10
BOT_MAX_SLIPPAGE_PCT=0.02
BOT_PAPER_LATENCY_MS=250
BOT_PAPER_LATENCY_JITTER_MS=100
BOT_BOOK_MAX_AGE_MS=5000
BOT_PAPER_PORTFOLIO_USDC=1000

# Optional base directory for archives created by `python -m polybot.recording`
# without `--output`. Defaults to `recordings` when unset.
DEFAULT_RECORDINGS_DIR=recordings

# Live execution is fail-closed. Keep this false for paper runs. A future live
# run must set both gates below and provide every wallet, funder, and CLOB value.
BOT_LIVE_ENABLED=false
POLYMARKET_PRIVATE_KEY=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
DEPOSIT_WALLET_ADDRESS=
